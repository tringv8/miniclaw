{
  "agents": {
    "defaults": {
      "workspace": "~/.miniclaw/workspace",
      "restrictToWorkspace": true,
      "modelName": "gpt-5.1-codex",
      "model": "openai-codex/gpt-5.1-codex",
      "provider": "auto",
      "maxTokens": 8192,
      "contextWindowTokens": 131072,
      "temperature": 0.7,
      "maxToolIterations": 20,
      "summarizeMessageThreshold": 20,
      "summarizeTokenPercent": 75,
      "splitOnMarker": false,
      "toolFeedback": {
        "enabled": false,
        "max_args_length": 300
      },
      "reasoningEffort": null,
      "timezone": "UTC"
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
    "sendMaxRetries": 3,
    "telegram": {
      "enabled": true,
      "token": "",
      "allowFrom": [""],
      "proxy": null,
      "replyToMessage": false,
      "reactEmoji": "👀",
      "groupPolicy": "mention",
      "connectionPoolSize": 32,
      "poolTimeout": 5.0,
      "streaming": true
    }
  },
  "providers": {
    "openai": {
      "apiKey": "",
      "apiBase": null,
      "extraHeaders": null
    },
    "gemini": {
      "apiKey": "",
      "apiBase": null,
      "extraHeaders": null
    },
    "groq": {
      "apiKey": "",
      "apiBase": null,
      "extraHeaders": null
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "heartbeat": {
      "enabled": true,
      "intervalS": 1800,
      "keepRecentMessages": 8
    }
  },
  "tools": {
    "web": {
      "proxy": null,
      "search": {
        "provider": "brave",
        "apiKey": "",
        "baseUrl": "",
        "maxResults": 5
      }
    },
    "exec": {
      "enable": true,
      "timeout": 60,
      "pathAppend": ""
    },
    "restrictToWorkspace": false,
    "mcpServers": {}
  }
}